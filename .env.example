# 이 파일을 복사해서 .env로 이름을 바꾸고 값을 채워주세요
# cp .env.example .env

APP_NAME=Life Dashboard
DEBUG=false

# ── 데이터베이스 ──────────────────────────────────────────
# 로컬 개발: SQLite (기본값)
DATABASE_URL=sqlite+aiosqlite:///./lifedash.db
# Docker / 프로덕션: PostgreSQL
# DATABASE_URL=postgresql+asyncpg://lifedash:password@db:5432/lifedash

# PostgreSQL 비밀번호 (docker-compose.yml에서 사용)
POSTGRES_PASSWORD=your_secure_password_here

# ── 보안 ─────────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# 단일 사용자 계정 — 반드시 변경
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── AI ────────────────────────────────────────────────────
# https://aistudio.google.com/ 에서 발급
GEMINI_API_KEY=your-gemini-api-key-here

# ── 프론트엔드 빌드 (Docker Compose) ──────────────────────
# 외부에서 접근 가능한 API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
