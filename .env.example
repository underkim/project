# 이 파일을 복사해서 .env로 이름을 바꾸고 값을 채워주세요
# cp .env.example .env

APP_NAME=Life Dashboard
DEBUG=false

# PostgreSQL (또는 SQLite)
DATABASE_URL=sqlite+aiosqlite:///./lifedash.db

# JWT 시크릿 (랜덤 문자열로 변경하세요)
JWT_SECRET=change-me-in-production

# 단일 사용자 계정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-password-here

# Google Gemini API 키 (aistudio.google.com에서 발급)
GEMINI_API_KEY=your-gemini-api-key-here
