# Life Dashboard - personal self-hosted configuration
# Copy this file to .env and replace every CHANGE_ME value before starting.

APP_NAME=Life Dashboard
DEBUG=false

# Local development defaults to SQLite. Docker Compose overrides this with PostgreSQL.
DATABASE_URL=sqlite+aiosqlite:///./lifedash.db

# Required by Docker Compose. Use a long, unique password.
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_DATABASE_PASSWORD

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_64_CHARACTER_RANDOM_SECRET

# Single-user login. This service does not provide public account registration.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_LOGIN_PASSWORD

# Browser origins allowed to call the API, separated by commas.
# Add the HTTPS origin when hosting on another machine.
CORS_ORIGINS=http://localhost:3000

# Optional. Leave empty to disable AI features.
GEMINI_API_KEY=

# URL that the user's browser can use to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:8000
